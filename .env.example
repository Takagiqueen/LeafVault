# LeafVault local Docker / self-hosting example environment.
# 复制为 .env 后再启动：
#   cp .env.example .env
#   docker compose up -d --build
#
# 本文件是示例模板，不要填写真实生产密钥后提交到 GitHub。

# =========================================================
# 基础安全配置
# =========================================================

# 必须修改：复制到 .env 后请改成强随机字符串。
# 生成方式：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-use-a-long-random-string

ACCESS_TOKEN_EXPIRE_DAYS=7

# =========================================================
# 登录态与 Cookie / CSRF 配置
# =========================================================

# 认证传输方式：
# - bearer：仅使用 Authorization Bearer
# - cookie：优先使用 HttpOnly Cookie
# - dual：Bearer + Cookie 双轨兼容
AUTH_TOKEN_TRANSPORT=dual

# 本地测试推荐开启 Cookie 优先，但仍保留 Bearer 兼容。
AUTH_PREFER_COOKIE=true
AUTH_COOKIE_ONLY_PREVIEW=true

# 本地测试阶段建议不再默认落盘 token 到 localStorage。
AUTH_STORE_TOKEN_IN_LOCALSTORAGE=false

# 保留 Bearer fallback，避免旧流程或测试不兼容。
AUTH_ALLOW_BEARER_FALLBACK=true


# Cookie 配置
AUTH_COOKIE_NAME=leafvault_access_token
COOKIE_SAMESITE=lax

# 本地是 http://localhost，不是 HTTPS，所以必须为 false。
# 生产 HTTPS 环境必须改为 true。
COOKIE_SECURE=false

COOKIE_MAX_AGE_SECONDS=604800

# CSRF 配置
CSRF_COOKIE_NAME=leafvault_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_PROTECTION_ENABLED=true
CSRF_ENFORCE_FOR_COOKIE_AUTH=true

# 注册、登录、健康检查、静态资源等公开接口不强制 CSRF。
CSRF_EXEMPT_PATHS=/api/login,/api/register,/api/send_code,/api/reset_password,/api/health,/api/deployment/status,/,/static,/favicon.ico,/manifest.json
CSRF_SAFE_METHODS=GET,HEAD,OPTIONS

# 本地测试为了避免退出卡住，可以允许 logout 无 CSRF 降级。
# 生产环境可改为 false。
CSRF_ALLOW_LOGOUT_WITHOUT_TOKEN=true

# =========================================================
# 数据库与上传目录
# =========================================================

# 本地 uvicorn 开发推荐：
#   ENVIRONMENT=development
#   DEPLOYMENT_MODE=local
#   DATABASE_PATH=D:/LeafVault/data.db
#   UPLOAD_DIR=D:/LeafVault/uploads
#
# Docker Compose 预览/自托管推荐使用下面的 /app 路径，它们会通过
# docker-compose.yml 挂载到宿主机 ./data 和 ./uploads。

# Docker Compose 会把 ./data 挂载到 /app/data，SQLite 会持久化到宿主机 ./data。
DATABASE_PATH=/app/data/leafvault.sqlite3

# Docker Compose 会把 ./uploads 挂载到 /app/uploads，用户上传图片会持久化到宿主机 ./uploads。
UPLOAD_DIR=/app/uploads

# =========================================================
# 部署环境
# =========================================================

# 本地 Docker 测试用 development。
# 公网生产部署应使用 production。
ENVIRONMENT=development

# local：本地开发 / 本机 Docker 测试
# lan：局域网测试
# public：公网部署
DEPLOYMENT_MODE=local

# 本地 Docker 测试必须使用 http://localhost:8000。
# 不要在本地测试用 https://localhost:8000。
PUBLIC_BASE_URL=http://localhost:8000

# 本地测试允许 localhost。
# 公网生产环境应改为你的真实域名，例如：
# TRUSTED_HOSTS=leafvault.example.com,www.leafvault.example.com
TRUSTED_HOSTS=localhost,127.0.0.1

# 本地不强制 HTTPS。
# 公网生产环境必须改为 true，并通过 Caddy/Nginx 提供 HTTPS。
FORCE_HTTPS=false

# Caddy 生产部署时使用。
# 本地 docker-compose.yml 测试可以保留 localhost。
LEAFVAULT_DOMAIN=localhost

# =========================================================
# 注册控制
# =========================================================

# 本地测试推荐 open，方便快速注册测试。
# 公网生产环境建议 invite 或 closed。
#
# 可选值：
# - open：任何人可注册
# - invite：需要邀请码
# - closed：关闭注册，只允许已有用户登录
REGISTRATION_MODE=open

# invite 模式下使用。
# 本地 open 模式不会用到它。
# 公网生产环境请改成强随机邀请码。
REGISTRATION_INVITE_CODE=change-me-invite-code

# =========================================================
# 安全响应头 / CSP
# =========================================================

SECURITY_HEADERS_ENABLED=true

# 本地也可以用 strict，但如果页面存在兼容性问题，可改为 dev。
# 公网生产建议 strict。
CSP_MODE=strict

CSP_REPORT_ONLY=false

# 本地资源优先，不允许随便新增外部 CDN。
CSP_LOCAL_VENDOR_ONLY=true

# 当前项目仍可能需要 inline 兼容。
# 后续可继续拆 inline script/style 后收紧。
CSP_ALLOWED_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_ALLOWED_STYLE_SRC="'self' 'unsafe-inline'"

# 允许 API 请求目标。
# 本地主要是 self；AI 功能可能请求 DeepSeek。
CSP_ALLOWED_CONNECT_SRC="'self' https://api.deepseek.com"

# =========================================================
# 上传与资源限制
# =========================================================

# 单张上传图片大小限制，单位 MB。
MAX_UPLOAD_SIZE_MB=10

# 单篇日记最多图片数。
MAX_DIARY_IMAGES_PER_ENTRY=9

# 每个用户最多云端快照数量。
MAX_CLOUD_SNAPSHOTS_PER_USER=5

# 单个云端密文快照 payload 最大大小，单位 MB。
MAX_CLOUD_SNAPSHOT_PAYLOAD_MB=100

# 单次增量同步最大批量。
MAX_SYNC_BATCH_SIZE=100

# 单条增量密文 payload 最大大小，单位 KB。
MAX_SYNC_CHANGE_PAYLOAD_KB=512

# 同步历史保留天数。
SYNC_HISTORY_RETENTION_DAYS=90

# 正式账号是否允许使用服务器上传能力。本地 Docker/自托管测试通常保持 true。
SERVER_UPLOAD_ENABLED=true

# Demo 模式是否允许上传到服务器。公开体验建议保持 false，避免占用服务器资源。
DEMO_SERVER_UPLOAD_ENABLED=false

# 允许上传的图片扩展名。
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,gif

# 允许上传的图片 MIME 类型。
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# =========================================================
# CORS
# =========================================================

# 本地 Docker 测试允许 localhost。
# 公网生产环境必须改成你的 HTTPS 域名，不要使用 *。
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# =========================================================
# 日志
# =========================================================

LOG_LEVEL=INFO

# =========================================================
# AI 润色配置
# =========================================================

# 本地测试可以留空。
# 留空时 AI 润色功能会提示暂不可用，不影响主流程。
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com

# =========================================================
# 邮箱验证码配置
# =========================================================

# 本地测试可以留空。
# 留空时邮箱验证码可能不可用，但不影响 Demo、本地功能、Docker 启动测试。
SENDER_EMAIL=
SENDER_PASSWORD=
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465

# =========================================================
# 生产环境提醒
# =========================================================

# 公网生产部署时，不要直接使用本文件。
# 请复制 .env.production.example 或手动修改：
#
# ENVIRONMENT=production
# DEPLOYMENT_MODE=public
# PUBLIC_BASE_URL=https://你的域名
# LEAFVAULT_DOMAIN=你的域名
# TRUSTED_HOSTS=你的域名
# ALLOWED_ORIGINS=https://你的域名
# FORCE_HTTPS=true
# COOKIE_SECURE=true
# REGISTRATION_MODE=invite
# REGISTRATION_INVITE_CODE=强随机邀请码
# SECRET_KEY=强随机密钥
#
# 生产环境必须通过 HTTPS 反向代理访问，不建议直接暴露 8000 端口。
