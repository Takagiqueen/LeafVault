# LeafVault public deployment example environment.
# Copy to .env.production and edit before using docker-compose.prod.yml.
# Do not commit the real .env.production file.

# Required: replace with a long random string before production.
# Example generator:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-use-a-long-random-string

ENVIRONMENT=production
DEPLOYMENT_MODE=public
REGISTRATION_MODE=invite
REGISTRATION_INVITE_CODE=change-me-invite-code
LEAFVAULT_DOMAIN=leafvault.example.com
PUBLIC_BASE_URL=https://leafvault.example.com
TRUSTED_HOSTS=leafvault.example.com
FORCE_HTTPS=true

ACCESS_TOKEN_EXPIRE_DAYS=7
DATABASE_PATH=/app/data/leafvault.sqlite3
UPLOAD_DIR=/app/uploads
LOG_LEVEL=INFO

# Public origin served by Caddy. Do not use * in production.
ALLOWED_ORIGINS=https://leafvault.example.com

# 本机 Docker 联调时可以复制本文件为 .env.production 后临时改为：
# ENVIRONMENT=development
# DEPLOYMENT_MODE=lan
# PUBLIC_BASE_URL=http://127.0.0.1:8001
# TRUSTED_HOSTS=127.0.0.1,localhost
# ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
# FORCE_HTTPS=false
# COOKIE_SECURE=false
# SERVER_UPLOAD_ENABLED=true
# DEMO_SERVER_UPLOAD_ENABLED=false
# 浏览器测试 Docker 版本请访问 http://127.0.0.1:8001。

SECURITY_HEADERS_ENABLED=true
CSP_MODE=strict
CSP_REPORT_ONLY=false
CSP_LOCAL_VENDOR_ONLY=true
CSP_ALLOWED_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_ALLOWED_STYLE_SRC="'self' 'unsafe-inline'"

AUTH_TOKEN_TRANSPORT=dual
AUTH_PREFER_COOKIE=true
AUTH_LOCALSTORAGE_TOKEN_COMPAT=true
AUTH_COOKIE_SESSION_CHECK_ENABLED=true
AUTH_LOCALSTORAGE_DEPRECATION_WARNING=false
AUTH_STORE_TOKEN_IN_LOCALSTORAGE=false
AUTH_ALLOW_BEARER_FALLBACK=true
AUTH_COOKIE_REQUIRED_IN_PRODUCTION=false
AUTH_COOKIE_NAME=leafvault_access_token

CSRF_COOKIE_NAME=leafvault_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_PROTECTION_ENABLED=true
CSRF_ENFORCE_FOR_COOKIE_AUTH=true
CSRF_EXEMPT_PATHS=/api/login,/api/register,/api/send_code,/api/reset_password,/api/health,/,/static,/favicon.ico,/manifest.json
CSRF_SAFE_METHODS=GET,HEAD,OPTIONS
CSRF_ALLOW_LOGOUT_WITHOUT_TOKEN=false

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE_SECONDS=604800

MAX_UPLOAD_SIZE_MB=10
MAX_DIARY_IMAGES_PER_ENTRY=9
MAX_CLOUD_SNAPSHOTS_PER_USER=5
MAX_CLOUD_SNAPSHOT_PAYLOAD_MB=100
MAX_SYNC_BATCH_SIZE=100
MAX_SYNC_CHANGE_PAYLOAD_KB=512
SERVER_UPLOAD_ENABLED=true
DEMO_SERVER_UPLOAD_ENABLED=false
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,gif
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# Optional AI polishing. Empty means AI features are unavailable.
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com

# Optional email verification. Never commit real mailbox credentials.
SENDER_EMAIL=
SENDER_PASSWORD=
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
